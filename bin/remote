#!/usr/bin/env bash
# POSIX wrapper for the `remote` entry point (SPEC-0022).
#
# Mirrors bin/eval and bin/embed. On Windows `uv run remote ...` works
# directly via the [project.scripts] console script; this wrapper is for
# Linux/Mac users to run `./bin/remote ...` from a clone.
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."
exec uv run remote "$@"
