# SPEC-0022 - remote runner configuration template.
#
# Copy to `.env.remote` (gitignored) and fill in real values. NEVER commit the
# filled-in file. See SPEC-0022 SS 6 (Non-functional requirements / Security)
# and ADR-0011 (artifact store + credentials boundary) for the model.

# --- SSH access to the leased cluster --------------------------------------
# Host alias must already be configured in your ~/.ssh/config with a working
# key. See e.g. `ssh -T <host>` returning a banner. Default alias name below.
AIC2026_REMOTE_SSH_HOST=aic2026-gpu

# Per-cluster base directory; the runner will `git clone` and `uv sync` here.
AIC2026_REMOTE_BASE=~/aic2026

# --- Repo to provision on the cluster --------------------------------------
# Used by `bin/remote provision --sha <sha>` to clone at a pinned SHA.
AIC2026_REMOTE_REPO_URL=git@github.com:htkchi/AIC2026-SCOAI.git

# --- SLURM defaults (optional; override per-job with --config srun_args=...)
AIC2026_REMOTE_SRUN_DEFAULT_ARGS="--gpus=1 --time=02:00:00 --mem=64G"

# --- Cloudflare R2 artifact store ------------------------------------------
# Endpoint = the ACCOUNT HOST ONLY: https://<account-id>.r2.cloudflarestorage.com
# Do NOT append the bucket name. The R2 dashboard shows the URL WITH the bucket
# (".../aic2026-artifacts"); pasting that makes list_objects_v2 return NoSuchKey
# (uploads still work, which hides the bug). R2Client strips a stray path defensively.
R2_ENDPOINT_URL=https://REPLACE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=aic2026-artifacts
R2_REGION=auto

# --- HuggingFace token (read-only is enough; only used for model downloads)
# Created at https://huggingface.co/settings/tokens
HF_TOKEN=REPLACE_ME
